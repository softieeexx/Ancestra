# Ancestra — Environment Variables

# WalletConnect Project ID (required for ConnectKit)
# Get one at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_ID=

# Deployed pool addresses (set after deployment)
NEXT_PUBLIC_POOL_STABLE=
NEXT_PUBLIC_POOL_CRYPTO=
NEXT_PUBLIC_POOL_ALT=

# Ritual Chain RPC
NEXT_PUBLIC_RPC_URL=https://rpc.ritualfoundation.org

# Deployer private key (for contract deployment)
PRIVATE_KEY=
